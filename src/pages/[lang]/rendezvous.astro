---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { useTranslations } from '../../i18n/utils';

export async function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'es' } },
    { params: { lang: 'tr' } },
    { params: { lang: 'fr' } },
    { params: { lang: 'de' } },
    { params: { lang: 'nl' } },
    { params: { lang: 'it' } },
    { params: { lang: 'ru' } },
  ];
}

const { lang } = Astro.params;
const t = useTranslations(lang);

const labels = {
    es: {
        title: "Reserva tu Cita",
        subtitle: "Comienza tu viaje hacia el vestido perfecto.",
        bodySize: "Talla / Medidas",
        silhouette: "Silueta Deseada",
        refProduct: "Referencia del Producto (Link o Nombre)",
        notes: "Notas Adicionales",
        submit: "ENVIAR SOLICITUD POR WHATSAPP",
        waGreeting: "Hola Mina Lidya, me gustaría solicitar una cita.",
        placeholderRef: "Ej. Modelo Valencia o link del producto",
        placeholderNotes: "Cuéntanos más sobre tus preferencias...",
        contact: "Contacto",
        name: "Nombre y Apellidos",
        placeholderName: "Tu nombre completo",
        weddingDate: "Fecha de la Boda",
    },
    en: {
        title: "Book your Appointment",
        subtitle: "Start your journey to the perfect dress.",
        weddingDate: "Wedding Date",
        bodySize: "Size / Measurements",
        silhouette: "Desired Silhouette",
        refProduct: "Product Reference (Link or Name)",
        notes: "Additional Notes",
        submit: "SEND REQUEST VIA WHATSAPP",
        contact: "Contact",
        name: "Full Name",
        placeholderName: "Your full name",
        waGreeting: "Hello Mina Lidya, I would like to book an appointment.",
        placeholderRef: "E.g. Valencia Model or product link",
        placeholderNotes: "Tell us more about your preferences...",
        weddingDate: "Wedding Date",
    },
    tr: {
        title: "Randevu Alın",
        subtitle: "Kusursuz gelinliğe giden yolculuğunuzu başlatın.",
        weddingDate: "Düğün Tarihi",
        bodySize: "Beden / Ölçüler",
        silhouette: "İstenilen Silüet",
        refProduct: "Ürün Referansı (Link veya İsim)",
        notes: "Ek Notlar",
        submit: "WHATSAPP İLE TALEP GÖNDER",
        contact: "İletişim",
        name: "Adınız Soyadınız",
        placeholderName: "Tam adınız",
        waGreeting: "Merhaba Mina Lidya, randevu talebinde bulunmak istiyorum.",
        placeholderRef: "Örn. Valencia Modeli veya ürün linki",
        placeholderNotes: "Tercihleriniz hakkında daha fazla bilgi verin...",
        weddingDate: "Düğün Tarihi",
    },
};

const L = labels[lang] || labels['es'];
---

<Layout title={`${L.title} | Mina Lidya`} lang={lang}>
  <Header />

  <main class="rendezvous-page">
    <section class="form-hero">
        <div class="container-small">
            <span class="script-label">Mina Lidya Atelier</span>
            <h1 class="hero-title">{L.title}</h1>
            <p class="hero-subtitle">{L.subtitle}</p>
            <div class="decorative-line"></div>
        </div>
    </section>

    <section class="appointment-section">
        <div class="container-small">
            <form id="appointment-form" class="elite-form">
                <div class="form-grid">
                    <div class="form-group full-width anim-up">
                        <label>{L.name}</label>
                        <input type="text" name="name" placeholder={L.placeholderName} required />
                    </div>
                    <div class="form-group anim-up">
                        <label>{L.weddingDate}</label>
                        <input type="date" name="weddingDate" required />
                    </div>
                    <div class="form-group anim-up">
                        <label>{L.bodySize}</label>
                        <input type="text" name="bodySize" placeholder="38, 40, M, L..." required />
                    </div>
                    <div class="form-group anim-up">
                        <label>{L.silhouette}</label>
                        <select name="silhouette">
                            <option value="Princess">Princess</option>
                            <option value="A-Line">A-Line</option>
                            <option value="Mermaid">Mermaid</option>
                            <option value="Empire">Empire</option>
                            <option value="Minimalist">Minimalist</option>
                        </select>
                    </div>
                    <div class="form-group anim-up">
                        <label>{L.refProduct}</label>
                        <input type="text" name="ref" placeholder={L.placeholderRef} />
                    </div>
                    <div class="form-group full-width anim-up">
                        <label>{L.notes}</label>
                        <textarea name="notes" placeholder={L.placeholderNotes}></textarea>
                    </div>
                </div>
                <div class="form-footer anim-up">
                    <button type="submit" class="elite-btn-submit">
                        <span class="btn-text">{L.submit}</span>
                    </button>
                    <p class="secure-text">Personal data is handled with highest discretion.</p>
                </div>
            </form>
        </div>
    </section>
  </main>

  <Footer />

  <script is:inline define:vars={{ L }}>
    const form = document.getElementById('appointment-form');
    form.addEventListener('submit', (e) => {
        e.preventDefault();
        const fd = new FormData(form);
        const data = Object.fromEntries(fd.entries());
        
        let message = `*${L.waGreeting}*\n\n`;
        message += `👤 *${L.name}:* ${data.name}\n`;
        message += `📅 *${L.weddingDate}:* ${data.weddingDate}\n`;
        message += `📏 *${L.bodySize}:* ${data.bodySize}\n`;
        message += `👗 *${L.silhouette}:* ${data.silhouette}\n`;
        message += `🔗 *${L.refProduct}:* ${data.ref || 'N/A'}\n`;
        message += `📝 *${L.notes}:* ${data.notes || 'N/A'}\n\n`;
        message += `_Sent via Mina Lidya Official Website_`;

        const encoded = encodeURIComponent(message);
        window.open(`https://wa.me/34632623300?text=${encoded}`, '_blank');
    });
  </script>
</Layout>

<style>
  @keyframes rosegold-shimmer {
    0% { background-position: -200% center; }
    100% { background-position: 200% center; }
  }
  .rendezvous-page {
    background: #fff;
    padding: 180px 0 120px;
    font-family: 'Inter', sans-serif;
  }
  .container-small {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 40px;
  }
  
  /* Hero Section */
  .form-hero { text-align: center; margin-bottom: 80px; }
  .script-label { font-family: 'Italianno', cursive; font-size: 32px; color: #D5A08D; display: block; margin-bottom: 10px; }
  .hero-title { font-family: 'Italiana', serif; font-size: 52px; text-transform: uppercase; letter-spacing: 4px; margin-bottom: 20px; }
  .hero-subtitle { font-family: 'Cormorant Garamond', serif; font-size: 20px; font-style: italic; color: #777; letter-spacing: 1px; }
  .decorative-line { width: 40px; height: 1px; background: #922724; margin: 30px auto; }

  /* Elite Form */
  .elite-form {
    background: #FDFDFD;
    padding: 60px;
    border: 1px solid #F0F0F0;
    box-shadow: 0 40px 100px rgba(0,0,0,0.03);
  }
  .form-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
  }
  .form-group.full-width { grid-column: span 2; }
  
  .form-group label {
    display: block;
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #999;
    margin-bottom: 10px;
    font-weight: 500;
  }
  .form-group input, 
  .form-group select, 
  .form-group textarea {
    width: 100%;
    padding: 15px 0;
    background: transparent;
    border: none;
    border-bottom: 1px solid #E0E0E0;
    font-family: 'Cormorant Garamond', serif;
    font-size: 18px;
    transition: all 0.3s ease;
    outline: none;
  }
  .form-group input:focus, 
  .form-group select:focus, 
  .form-group textarea:focus {
    border-bottom-color: #922724;
  }
  .form-group textarea { height: 100px; resize: none; margin-top: 10px; }

  /* Submit Button */
  .form-footer { margin-top: 60px; text-align: center; }
  .elite-btn-submit {
    background: #111;
    color: #fff;
    border: none;
    padding: 20px 45px;
    font-family: 'Inter', sans-serif;
    font-size: 12px;
    letter-spacing: 3px;
    font-weight: 600;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 15px;
    transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
  }
  .elite-btn-submit:hover {
    background: linear-gradient(90deg, #D5A08D, #f2f2f2, #EACEB4, #f2f2f2, #D5A08D);
    background-size: 200% auto;
    animation: rosegold-shimmer 3s linear infinite;
    transform: translateY(-5px);
    box-shadow: 0 15px 40px rgba(213, 160, 141, 0.4);
    color: #fff;
  }
  .wa-icon { width: 18px; filter: invert(0); }
  
  .secure-text { font-size: 10px; color: #CCC; margin-top: 25px; letter-spacing: 1px; }

  @media (max-width: 768px) {
    .form-grid { grid-template-columns: 1fr; }
    .form-group.full-width { grid-column: span 1; }
    .elite-form { padding: 30px; }
    .hero-title { font-size: 38px; }
  }
</style>
