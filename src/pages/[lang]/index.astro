---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Grid from '../../components/Grid.astro';
import CategoryList from '../../components/CategoryList.astro';
import HeroSlider from '../../components/HeroSlider.astro';
import Inspoboard from '../../components/Inspoboard.astro';
import GalleryHome from '../../components/GalleryHome.astro';
import Editorials from '../../components/Editorials.astro';

export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'tr' } },
    { params: { lang: 'es' } },
    { params: { lang: 'fr' } },
    { params: { lang: 'it' } },
    { params: { lang: 'de' } },
    { params: { lang: 'nl' } },
    { params: { lang: 'ru' } },
  ];
}

const { lang } = Astro.params;
---

<Layout title={`Mina Lidya - ${lang.toUpperCase()}`} description={`Mina Lidya ${lang.toUpperCase()} version - Bridal, Atelier & Alta Costura`} lang={lang}>
    <Header />
    <main>
        <HeroSlider lang={lang} />
        <CategoryList lang={lang} />
        <Grid lang={lang} />
        <Inspoboard lang={lang} />
        <GalleryHome lang={lang} />
        <Editorials lang={lang} />
    </main>
    <Footer lang={lang} />
</Layout>
