<script is:inline define:vars={{ products, lang, attrTranslations }}>
    class ProductFilter {
        constructor() {
            this.allProducts = products;
            this.filteredProducts = [];
            this.visibleCount = 16;
            this.activeCat = 'all';
            this.modestOnly = false;
            this.currentLang = lang;

            this.grid = document.getElementById('products-grid');
            this.loadMoreBtn = document.getElementById('load-more-btn');
            this.countEl = document.getElementById('product-count');
            this.pills = document.querySelectorAll('.cat-pill');
            this.modestToggle = document.getElementById('modest-toggle');
            
            this.lightbox = document.getElementById('product-lightbox');
            this.mainSwiper = null;
            this.thumbsSwiper = null;

            this.init();
        }

        catNormalize(s) {
            return String(s)
                .toLowerCase()
                .replace(/ş/g, 's').replace(/Ş/g, 's')
                .replace(/ı/g, 'i').replace(/İ/g, 'i').replace(/I/g, 'i')
                .replace(/ö/g, 'o').replace(/Ö/g, 'o')
                .replace(/ü/g, 'u').replace(/Ü/g, 'u')
                .replace(/ç/g, 'c').replace(/Ç/g, 'c')
                .replace(/ğ/g, 'g').replace(/Ğ/g, 'g')
                .replace(/-/g, ' ')
                .replace(/\s+/g, ' ')
                .trim();
        }

        getProductCategories(p) {
            let cats = [];
            if (p.category && typeof p.category === 'string') {
                p.category.split(',').forEach(c => cats.push(c.trim()));
            }
            if (Array.isArray(p.categories)) {
                p.categories.forEach(c => {
                    if (typeof c === 'string') {
                        c.split(',').forEach(s => cats.push(s.trim()));
                    } else if (c && c.slug) cats.push(c.slug);
                      else if (c && c.name) cats.push(c.name);
                });
            }
            return [...new Set(cats.filter(Boolean).map(c => this.catNormalize(c)))];
        }

        init() {
            const urlParams = new URLSearchParams(window.location.search);
            this.activeCat = urlParams.get('cat') || 'all';
            const modestParam = urlParams.get('modest');
            this.modestOnly = modestParam === 'true' ? true : modestParam === 'false' ? false : null;

            // Pill clicks
            this.pills.forEach(pill => {
                const cat = pill.getAttribute('data-category');
                if (this.catNormalize(cat) === this.catNormalize(this.activeCat)) {
                    pill.classList.add('active');
                }

                pill.onclick = () => {
                    this.pills.forEach(p => p.classList.remove('active'));
                    pill.classList.add('active');
                    this.activeCat = cat;
                    this.visibleCount = 16;
                    this.updateURL();
                    this.applyFilters();
                };
            });

            // Modest toggle (3 states: null=all, true=ON/Evet, false=OFF/Hayir)
            if (this.modestToggle) {
                this._updateModestBtn();
                this.modestToggle.onclick = () => {
                    // Cycle: null -> true -> false -> null
                    if (this.modestOnly === null) this.modestOnly = true;
                    else if (this.modestOnly === true) this.modestOnly = false;
                    else this.modestOnly = null;
                    this._updateModestBtn();
                    this.visibleCount = 16;
                    this.updateURL();
                    this.applyFilters();
                };
            }

            // Load more
            if (this.loadMoreBtn) {
                this.loadMoreBtn.onclick = () => {
                    this.visibleCount += 16;
                    this.renderGrid();
                };
            }

            // Lightbox close
            const closeBtn = this.lightbox.querySelector('.close-lightbox');
            if (closeBtn) closeBtn.onclick = () => this.closeLightbox();
            this.lightbox.onclick = (e) => {
                if (e.target === this.lightbox) this.closeLightbox();
            };

            this.applyFilters();
        }

        _updateModestBtn() {
            if (!this.modestToggle) return;
            this.modestToggle.classList.remove('active', 'modest-off');
            if (this.modestOnly === true) {
                this.modestToggle.classList.add('active');
                this.modestToggle.textContent = this.modestToggle.dataset.on || 'TESETTÜR UYUMU: ON';
            } else if (this.modestOnly === false) {
                this.modestToggle.classList.add('modest-off');
                this.modestToggle.textContent = this.modestToggle.dataset.off || 'TESETTÜR UYUMU: OFF';
            } else {
                this.modestToggle.textContent = this.modestToggle.dataset.label || 'TESETTÜR UYUMU';
            }
        }

        updateURL() {
            const url = new URL(window.location);
            url.searchParams.set('cat', this.activeCat);
            if (this.modestOnly === null) {
                url.searchParams.delete('modest');
            } else {
                url.searchParams.set('modest', this.modestOnly);
            }
            window.history.pushState({}, '', url);
        }

        openLightbox(productId) {
            const product = this.allProducts.find(p => p.id === productId || p.id == productId);
            if (!product) return;

            this.renderLightbox(product);
            
            this.lightbox.classList.add('active');
            document.body.style.overflow = 'hidden';

            if (this.thumbsSwiper) this.thumbsSwiper.destroy();
            if (this.mainSwiper) this.mainSwiper.destroy();

            this.thumbsSwiper = new Swiper(".lb-thumbs-swiper", {
                spaceBetween: 10,
                slidesPerView: 5,
                freeMode: true,
                watchSlidesProgress: true,
            });

            this.mainSwiper = new Swiper(".lb-main-swiper", {
                loop: (product.images && product.images.length > 1),
                speed: 800,
                slidesPerView: 1,
                thumbs: {
                    swiper: this.thumbsSwiper,
                },
                navigation: {
                    nextEl: ".lb-next",
                    prevEl: ".lb-prev",
                }
            });
        }

        renderLightbox(product) {
            const lbWrapper = document.getElementById('lb-swiper-wrapper');
            const lbThumbsWrapper = document.getElementById('lb-thumbs-wrapper');
            const lbTitle = document.getElementById('lb-title');
            const lbDesc = document.getElementById('lb-desc');
            const lbAttrs = document.getElementById('lb-attributes');
            const lbActions = document.getElementById('lb-actions');

            const images = product.images || (product.image ? [{ src: product.image }] : []);
            const displayName = (product.title[this.currentLang] || product.title.tr || product.productName || "Model").split(' ')[0].toUpperCase();

            lbWrapper.innerHTML = images.map(img => `
                <div class="swiper-slide"><img src="${img.src}" alt="${displayName}"></div>
            `).join('');

            lbThumbsWrapper.innerHTML = images.map(img => `
                <div class="swiper-slide"><img src="${img.src}" alt="thumb"></div>
            `).join('');

            lbTitle.innerText = displayName;
            
            let descStr = product.shortDescription?.[this.currentLang] || product.shortDescription?.tr || "";
            if (Array.isArray(descStr)) descStr = descStr.map(b => b.children ? b.children.map(c => c.text).join('') : '').join(' ');
            
            const words = String(descStr).split(/\s+/);
            const truncated = words.length > 50 ? words.slice(0, 50).join(' ') + '...' : descStr;
            lbDesc.innerText = truncated;

            const attrKeys = ["Etek Kesimi", "Kumaş", "Kol", "Yaka", "Tesettür Uyumu"];
            lbAttrs.innerHTML = attrKeys.map(key => {
                const val = (product.mappedAttributes || {})[key];
                if (!val || val === 'Hayır') return '';
                
                // Translate key and value
                const tKey = (attrTranslations[this.currentLang] && attrTranslations[this.currentLang][key]) || key;
                const tVal = String(val).split(',').map(v => {
                    const trimmed = v.trim();
                    const lookup = attrTranslations[this.currentLang] || {};
                    // Try exact, then capitalized version
                    return lookup[trimmed] || lookup[trimmed.charAt(0).toUpperCase() + trimmed.slice(1).toLowerCase()] || trimmed;
                }).join(', ');

                return `<div class="lb-attr"><label>${tKey}</label><span>${tVal}</span></div>`;
            }).join('');

            const origin = window.location.origin;
            const productUrl = `${origin}/${this.currentLang}/product/${product.slug || product.id}`;
            
            // Localize message
            let waMsgTemplate = "Hello, I would like to get information about the {model} model.\n\nProduct Link: {url}";
            if (this.currentLang === 'es') waMsgTemplate = "Hola, me gustaría recibir información sobre el modelo {model}.\n\nEnlace del producto: {url}";
            else if (this.currentLang === 'tr') waMsgTemplate = "Merhaba, {model} modeli hakkında bilgi almak istiyorum.\n\nÜrün Linki: {url}";
            
            const waText = waMsgTemplate.replace('{model}', displayName).replace('{url}', productUrl);

            lbActions.innerHTML = `
                <a href="${productUrl}" class="actions-item-btn btn-dark">${displayName} →</a>
                <a href="https://wa.me/34632623300?text=${encodeURIComponent(waText)}" target="_blank" class="actions-item-btn btn-outline-dark">WHATSAPP</a>
            `;
        }

        closeLightbox() {
            this.lightbox.classList.remove('active');
            document.body.style.overflow = '';
        }

        applyFilters() {
            const target = this.catNormalize(this.activeCat);
            
            // 1. Initial filter based on draft status
            let baseProducts = this.allProducts.filter(p => p.status !== 'draft');

            // 2. Recency sorting logic (SKU Descending)
            const sortBySku = (a, b) => {
                const skuA = (a.sku || '').toUpperCase();
                const skuB = (b.sku || '').toUpperCase();
                return skuB.localeCompare(skuA);
            };

            if (target === 'all') {
                // HIERARCHICAL SORTING
                // 1. Gelinlik (8 newest)
                // 2. Tesettür Gelinlik (8 newest)
                // 3. After Party (8 newest)
                // 4. Abiye (8 newest)
                // 5. Others

                const getCatMatches = (p, catKey) => {
                    const pCats = this.getProductCategories(p);
                    if (catKey === 'gelinlik') {
                        return pCats.some(c => c === 'gelinlik' || c === 'wedding-gown' || c === 'wedding gown' || c === 'nikah');
                    }
                    if (catKey === 'tesettur-gelinlik') {
                        return pCats.some(c => c === 'tesettur-gelinlik' || c === 'tesettur gelinlik');
                    }
                    if (catKey === 'after-party') {
                        return pCats.some(c => c === 'after-party' || c === 'after party');
                    }
                    if (catKey === 'abiye') {
                        return pCats.some(c => c === 'abiye' || c === 'noche' || c === 'evening');
                    }
                    return false;
                };

                const sortedAll = [...baseProducts].sort(sortBySku);
                
                const selectedIds = new Set();
                const finalOrder = [];

                const addGroup = (catKey) => {
                    const group = sortedAll.filter(p => !selectedIds.has(p.id) && getCatMatches(p, catKey)).slice(0, 8);
                    group.forEach(p => {
                        finalOrder.push(p);
                        selectedIds.add(p.id);
                    });
                };

                addGroup('gelinlik');
                addGroup('tesettur-gelinlik');
                addGroup('after-party');
                addGroup('abiye');

                // Add remaining
                const remaining = sortedAll.filter(p => !selectedIds.has(p.id));
                finalOrder.push(...remaining);

                this.filteredProducts = finalOrder;

            } else {
                // STANDARD FILTERING per category
                this.filteredProducts = baseProducts.filter(p => {
                    const pCats = this.getProductCategories(p);
                    if (target === 'gelinlik') {
                        return pCats.some(c =>
                            c === 'gelinlik' || c === 'wedding gown' || c === 'wedding-gown' ||
                            c === 'nikah elbisesi' || c === 'nikah-elbisesi'
                        );
                    } else if (target === 'tesettur gelinlik') {
                        // Virtual category: Bridal + Modest
                        const isGelinlik = pCats.some(c =>
                            c === 'gelinlik' || c === 'wedding gown' || c === 'wedding-gown' ||
                            c === 'nikah elbisesi' || c === 'nikah-elbisesi' ||
                            c === 'tesettur-gelinlik' || c === 'tesettur gelinlik'
                        );
                        const isModest = p.isModest === true ||
                                         p.isModest === 'true' ||
                                         p.isModest === 'yes' ||
                                         (p.mappedAttributes && (
                                             p.mappedAttributes['Tesettür Uyumu'] === 'Evet' ||
                                             p.mappedAttributes['Tesettür Uyumu'] === 'Yes'
                                         ));
                        return isGelinlik && isModest;
                    } else if (target === 'nisan gelinlik' || target === 'nisan-gelinlik' || target === 'nisan elbisesi' || target === 'nisan-elbisesi') {
                        return pCats.some(c =>
                            c === 'nisan elbisesi' || c === 'nisan-elbisesi' ||
                            c === 'soz elbisesi' || c === 'soz-elbisesi' ||
                            c === 'nisan' || c === 'soz'
                        );
                    } else {
                        return pCats.some(c => c === target || c.includes(target));
                    }
                }).sort(sortBySku);
            }

            // 3. APPLY MODEST TOGGLE FILTER on the result
            if (this.modestOnly !== null) {
                this.filteredProducts = this.filteredProducts.filter(p => {
                    const isModest = p.isModest === true ||
                                     p.isModest === 'true' ||
                                     p.isModest === 'yes' ||
                                     (p.mappedAttributes && (
                                         p.mappedAttributes['Tesettür Uyumu'] === 'Evet' ||
                                         p.mappedAttributes['Tesettür Uyumu'] === 'Yes'
                                     ));
                    if (this.modestOnly === true && !isModest) return false;
                    if (this.modestOnly === false && isModest) return false;
                    return true;
                });
            }

            if (this.countEl) this.countEl.innerText = this.filteredProducts.length;
            this.renderGrid();
        }

        renderGrid() {
            if (!this.grid) return;
            const toShow = this.filteredProducts.slice(0, this.visibleCount);

            if (toShow.length === 0) {
                this.grid.innerHTML = '<div class="no-products" style="padding: 100px; text-align: center; color: #666; font-family: Italiana;">NO PRODUCTS FOUND</div>';
            } else {
                this.grid.innerHTML = toShow.map(p => {
                    const trName = p.title[this.currentLang] || p.title.tr || p.productName || "Model";
                    const displayName = String(trName).trim().split(' ')[0].toUpperCase();
                    const img = p.image || (p.images && p.images[0] ? p.images[0].src : '/img/placeholder.jpg');
                    const sku = p.sku || '';

                    const slug = p.slug || p.id;
                    const productLink = `/${this.currentLang}/product/${slug}`;
                    const previewText = this.currentLang === 'tr' ? 'ÖNİZLEME' : (this.currentLang === 'es' ? 'VISTA PREVIA' : 'PREVIEW');
                    const detailsText = this.currentLang === 'tr' ? 'DETAYLAR' : (this.currentLang === 'es' ? 'DETALLES' : 'DETAILS');

                    return `
                        <div class="product-card">
                            <div class="product-card__image">
                                <img src="${img}" alt="${displayName}" loading="lazy">
                                <div class="product-card__actions">
                                    <button class="action-btn preview-btn" onclick="event.stopPropagation(); window.shopFilter.openLightbox('${p.id}')">${previewText}</button>
                                    <a href="${productLink}" class="action-btn details-btn">${detailsText}</a>
                                </div>
                            </div>
                            <div class="product-card__info">
                                <span class="product-card__sku">${sku}</span>
                                <h3 class="product-card__title">${displayName}</h3>
                            </div>
                        </div>
                    `;
                }).join('');
            }

            if (this.loadMoreBtn) {
                this.loadMoreBtn.style.display = (this.visibleCount < this.filteredProducts.length) ? 'inline-block' : 'none';
            }
        }
    }

    window.shopFilter = new ProductFilter();
</script>
